# Inmo24x7 Backoffice Environment Variables

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Authentication Settings
# Set to "true" to enable Supabase Auth, "false" to disable (no login required)
VITE_USE_SUPABASE_AUTH=false

# Backend API URL
# Use full URL like "http://localhost:3000" for local
# Use "https://api.inmo24x7.com" for shared/prod backend
VITE_API_URL=https://api.inmo24x7.com
